{
    "name": "karabinse/telnect-sms",
    "description": "Send SMS text message using Telnect API",
    "homepage": "https://github.com/karabinse/telnect-sms",
    "license": "MIT",
    "authors": [
        {
            "name": "Karabin AB",
            "email": "info@karabin.se",
            "homepage": "https://karabin.se",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/notifications": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Karabin\\TelnectSms\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Karabin\\TelnectSms\\Test\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-clover=coverage.clover"
    },
    "config": {
        "sort-packages": true
    }
}